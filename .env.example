# =============================================================
# Pilot Broker Backend — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env — ele está no .gitignore.
# =============================================================

# ---- Perfil Spring ----
SPRING_PROFILES_ACTIVE=dev

# ---- Banco de Dados (DEV usa root sem senha por padrão) ----
DB_USERNAME=root
DB_PASSWORD=
# DB_URL é obrigatório apenas em PROD
# DB_URL=jdbc:mysql://seu-servidor:3306/pilot_broker?...

# ---- JWT ----
# Gere um secret seguro com: openssl rand -base64 64
JWT_SECRET=SUBSTITUA_POR_UM_SECRET_SEGURO_DE_NO_MINIMO_64_CARACTERES
JWT_EXPIRATION=86400000

# ---- FMP API (Financial Modeling Prep) ----
# Documentação: https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=SUBSTITUA_PELA_SUA_API_KEY

# ---- RabbitMQ ----
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# ---- Servidor ----
SERVER_PORT=8080
